# ABIS backend environment — copy to backend/.env and adjust.
# Values below match local dev defaults (docker compose db + redis).

DJANGO_SETTINGS_MODULE=config.settings.dev
DJANGO_SECRET_KEY=django-insecure-abis-dev-only
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# PostgreSQL 16 — docker compose publishes on 5433 (host 5432 is often taken)
DATABASE_URL=postgres://abis:abis@localhost:5433/abis

# Redis 7 — celery broker / results / channels
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1
CHANNELS_REDIS_URL=redis://localhost:6379/2

# Frontend origin (Vite dev server)
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Biometric template encryption key (Fernet). Generate your own:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ABIS_FIELD_KEY=neP8RPJf4BdE388S-9W5FDvEw0bA6fGfS6nkjG0atJY=
# NFIQ-like acceptance threshold (records scoring below are rejected)
ABIS_QUALITY_THRESHOLD=2
